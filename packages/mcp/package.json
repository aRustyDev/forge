{
  "name": "@forge/mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "FORGE_MCP_TRANSPORT=http bun run src/index.ts",
    "dev:stdio": "bun run src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector bun run src/index.ts",
    "inspect:http": "npx @modelcontextprotocol/inspector --transport http --server-url http://localhost:5174/mcp",
    "build": "bun build src/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "@forge/core": "workspace:*",
    "@forge/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
